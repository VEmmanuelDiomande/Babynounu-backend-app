# ============================================================
# Environment variables - BabyNounu Backend
# Production example : copier ce fichier en .env et remplir
# les valeurs réelles. Ne JAMAIS committer le fichier .env.
# ============================================================

NODE_ENV=production
PORT=3000

# ------------------------------------------------------------
# URLs du serveur
# ------------------------------------------------------------
HOST_URL="https://baby.djoumaf.net"
HOST_URL_LOCAL="http://localhost"
FRONTEND_URL="https://baby.djoumaf.net"

# Origines autorisées par CORS (séparées par des virgules)
CORS_ORIGINS="https://baby.djoumaf.net,https://www.babynounu.com"

# ------------------------------------------------------------
# Base de données
# Format Prisma MariaDB/MySQL :
# DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
# ------------------------------------------------------------
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=disable"

# ------------------------------------------------------------
# JWT
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ------------------------------------------------------------
JWT_SECRET="CHANGE_ME_GENERATE_WITH_NODE_CRYPTO"
JWT_EXPIRES_IN=365d
JWT_REFRESH_SECRET="CHANGE_ME_GENERATE_WITH_NODE_CRYPTO"
JWT_REFRESH_EXPIRES_IN=7d

# ------------------------------------------------------------
# Paiement - CinetPay
# ------------------------------------------------------------
CINETPAY_API_KEY=""
CINETPAY_API_PASSWORD=""
CINETPAY_COUNTRY=CI
CINETPAY_LANG=fr
CINETPAY_NOTIFY_URL="https://baby.djoumaf.net/payments/notify"

# ------------------------------------------------------------
# Paiement - GeniusPay (API Marchand)
# Récupérer les credentials sur https://pay.genius.ci
# ------------------------------------------------------------
GENIUSPAY_API_KEY=""
GENIUSPAY_API_SECRET=""
GENIUSPAY_NOTIFY_URL="https://api.babynounu.com/payments/notify"
GENIUSPAY_WALLET_ID="uuid_de_votre_wallet_payout"
GENIUSPAY_LANG="fr"
SUBSCRIPTION_DURATION_DAYS=30

# ------------------------------------------------------------
# Admin (utilisé pour le seed / identification admin)
# ------------------------------------------------------------
USER_ADMIN_ID="admin-babynounu-01"
USER_ADMIN_INFO={
  "slug": "admin-01",
  "email": "admin@babynounu.com",
  "password": "CHANGER_CE_MOT_DE_PASSE",
  "role": "admin",
  "type_profil": "administrateur"
}

# ------------------------------------------------------------
# Notifications push (Firebase Cloud Messaging)
# En production, préférez le montage d'un fichier JSON sécurisé
# et laissez FIREBASE_SERVICE_ACCOUNT_JSON vide.
# ------------------------------------------------------------
FIREBASE_SERVICE_ACCOUNT_PATH=""
FIREBASE_SERVICE_ACCOUNT_JSON=''
